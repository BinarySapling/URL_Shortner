# ============================================================
# URL Shortener — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# Public base URL — used to build short links returned by the API
# Use your EC2 public IP or domain name
BASE_URL=http://your-ec2-ip-or-domain

# MongoDB Atlas connection string
# Get from: cloud.mongodb.com → your cluster → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Upstash Redis connection URL (TLS — starts with rediss://)
# Get from: console.upstash.io → your database → Connect tab
REDIS_URL=rediss://default:<token>@<host>.upstash.io:6379

# Rate limiting (requests per window)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# URL cache TTL in seconds (default: 24 hours)
CACHE_TTL=86400
